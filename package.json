{
  "name": "agentkit",
  "private": true,
  "description": "AI Agent Kit - Lit Web Components + Mastra + Hono",
  "keywords": [
    "agent",
    "ai",
    "chatbot",
    "hono",
    "lit",
    "llm",
    "mastra",
    "web-components"
  ],
  "homepage": "https://github.com/weishaodaren/agentkit#readme",
  "bugs": {
    "url": "https://github.com/weishaodaren/agentkit/issues"
  },
  "author": {
    "name": "weishaodaren",
    "email": "weishaodaren@gmail.com",
    "url": "https://github.com/weishaodaren"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weishaodaren/agentkit.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/weishaodaren"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "bootstrap": "pnpm install",
    "dev": "turbo watch dev --ui=tui",
    "dev:web": "turbo watch dev --filter=web",
    "dev:server": "turbo watch dev --filter=server",
    "dev:docs": "turbo watch dev --filter=docs",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:all": "pnpm clean && rm -rf apps/*/node_modules packages/*/node_modules",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "turbo run format",
    "format:check": "turbo run format -- --check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --ui=stream",
    "test:watch": "vitest",
    "test:coverage": "turbo run test --ui=stream -- --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@vitest/coverage-v8": "catalog:",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.75.0",
    "turbo": "2.10.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.2"
}
