{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "format": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "test/**/*.ts",
        "tsconfig.json",
        "package.json"
      ]
    },
    "test:coverage": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "test/**/*.ts",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    }
  },
  "ui": "tui"
}
