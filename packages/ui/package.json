{
  "name": "@agentkit/ui",
  "version": "0.1.0",
  "description": "AgentKit UI - Web Components library built with Lit and Tailwind CSS",
  "keywords": [
    "lit",
    "tailwindcss",
    "ui-library",
    "web-components"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/weishaodaren/agentkit",
    "directory": "packages/ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "oxlint .",
    "format": "oxfmt write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lit-labs/signals": "^0.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lit": "^3.3.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "catalog:",
    "unplugin-dts": "^1.0.2",
    "vite": "catalog:"
  }
}
