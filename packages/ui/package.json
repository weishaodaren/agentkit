{
  "name": "@agentkit/ui",
  "version": "0.1.0",
  "description": "AgentKit UI - Web Components library built with Lit and Tailwind CSS",
  "keywords": [
    "lit",
    "tailwindcss",
    "ui-library",
    "web-components"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/weishaodaren/agentkit",
    "directory": "packages/ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adaptor/react": {
      "types": "./dist/adaptor/react.d.ts",
      "import": "./dist/adaptor/react.js"
    },
    "./adaptor/react-plugins": {
      "types": "./dist/adaptor/react-plugins.d.ts",
      "import": "./dist/adaptor/react-plugins.js"
    },
    "./adaptor/vue": {
      "types": "./dist/adaptor/vue.d.ts",
      "import": "./dist/adaptor/vue.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./code-highlighter": {
      "types": "./dist/code-highlighter.d.ts",
      "import": "./dist/code-highlighter.js"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "oxlint .",
    "format": "oxfmt write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lit-labs/motion": "^1.1.0",
    "@lit-labs/signals": "^0.3.0",
    "@lit-labs/virtualizer": "^2.1.1",
    "@lit/react": "^1.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lit": "^3.3.3",
    "lit-html": "^3.3.3",
    "lucide-static": "^1.21.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tailwindcss": "^4.3.1",
    "typescript": "catalog:",
    "unplugin-dts": "^1.0.2",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "highlight.js": ">=11",
    "marked": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "highlight.js": {
      "optional": true
    },
    "marked": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
