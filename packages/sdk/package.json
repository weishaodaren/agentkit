{
  "name": "@agentkit/sdk",
  "version": "0.1.0",
  "description": "AgentKit SDK - Unified Mastra client wrapper for AI Agent development",
  "keywords": [
    "agent",
    "ai",
    "chat",
    "llm",
    "mastra",
    "sdk"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "format": "oxfmt write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentkit/shared": "workspace:*",
    "@mastra/client-js": "1.28.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:"
  }
}
